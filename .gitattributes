# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.gradle text eol=lf

# Shell scripts - must have LF line endings and execute permission
*.sh text eol=lf
gradlew text eol=lf
gradlew.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.apk binary
*.jar binary
*.aar binary
gradle-wrapper.jar binary